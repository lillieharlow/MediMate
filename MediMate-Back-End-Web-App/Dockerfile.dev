# syntax=docker/dockerfile:1

# Use Node.js 20 Alpine image for development environment
FROM node:20-alpine

# Set working directory inside the container
WORKDIR /app

# Copy package files and install dependencies
COPY package*.json ./
RUN npm ci

# Copy the rest of the application code
COPY . .

# Start the dev server (.env variables provided by Docker Compose env_file)
CMD ["npm", "run", "dev"]